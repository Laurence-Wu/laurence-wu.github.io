---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { formatDate } from '../utils/date';

export interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  image?: string;
  tags?: string[];
  frontPicture?: string | null;
}

const { title, description, pubDate, updatedDate, author = 'Laurence', image, tags = [], frontPicture = null } = Astro.props;
---

<BaseLayout title={title} description={description} image={image}>
  <main class="blog-post">
    <article>
      <header class="post-header">
        <h1>{title}</h1>
        <div class="post-meta">
          <time datetime={pubDate.toISOString()}>
            {formatDate(pubDate)}
          </time>
          {author && <span class="author">by {author}</span>}
          {updatedDate && (
            <span class="updated">
              (Updated: <time datetime={updatedDate.toISOString()}>
                {formatDate(updatedDate)}
              </time>)
            </span>
          )}
        </div>
        {tags.length > 0 && (
          <div class="tags">
            {tags.map(tag => (
              <a href={`/blog/tag/${tag}/`} class="tag">{tag}</a>
            ))}
          </div>
        )}
      </header>

      {image && (
        <div class="post-image">
          <img src={image} alt={title} />
        </div>
      )}
      
      <TableOfContents />
      
      <div class="content-with-sidebar">
        <div class="post-content prose-content main-content">
          <slot />
        </div>
        
        {frontPicture && (
          <div class="front-picture-sidebar">
            <h4>Article Preview</h4>
            <img 
              src={frontPicture} 
              alt={`${title} preview`}
              class="front-picture-image"
            />
          </div>
        )}
      </div>
      

    </article>
  </main>
  <footer class="blog-footer">
    <div class="container">
      <a href="/blog" class="back-link">← Back to Blog</a>
    </div>
  </footer>
<script define:vars={{ tags }}>
  tags.forEach(tag => {
    if (tag.includes('/')) {
      console.warn(`[Tag Warning] The tag "${tag}" contains a slash, which may cause issues with URL routing. Please consider using a different separator like a hyphen (-).`);
    }
  });
</script>

<script>
  // Load mermaid.js from CDN and initialize diagrams
  if (document.querySelector('.mermaid')) {
    const s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js';
    s.onload = () => {
      (window as any).mermaid.initialize({
        startOnLoad: false,
        theme: 'neutral',
        themeVariables: {
          primaryColor: '#39647c',
          primaryTextColor: '#2E3A59',
          lineColor: '#8A9A7E',
          background: '#F4E9D8',
        }
      });
      (window as any).mermaid.run({ querySelector: '.mermaid' });
    };
    document.head.appendChild(s);
  }
</script>

</BaseLayout>

<style>
  .blog-post {
    max-width: 800px;
    margin: 0 auto;
    padding: 1rem 1rem;
    margin-top: -1rem;
    min-height: calc(100vh - 180px);
  }
  
  @media (min-width: 1201px) {
    .blog-post {
      margin-left: 340px;
      margin-right: auto;
      max-width: calc(100vw - 380px);
    }
    
    .blog-footer .container {
      margin-left: 340px;
      margin-right: auto;
    }
  }
  
  .post-header {
    margin-bottom: 1rem;
    margin-top: 0.5rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1rem;
    padding: 1.5rem;
    border-radius: 12px;
  }
  
  .blog-footer {
    background: var(--deep-navy);
    padding: 1.5rem 0;
    border-top: 3px solid var(--color-border);
    margin-top: 1rem;
    margin-bottom: -1rem;
    position: relative;
    overflow: hidden;
    width: 100%;
  }
  
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1rem;
    position: relative;
    z-index: 2;
  }
  
  .back-link {
    color: var(--warm-neutral);
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
  }

  .post-header h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    line-height: 1.2;
    color: var(--deep-navy);
    font-family: var(--font-heading);
  }

  .post-image {
    margin: 2rem 0;
    text-align: center;
  }

  .post-image img {
    max-width: 100%;
    border-radius: 8px;
  }
  
  
  .post-meta {
    color: var(--color-text-light);
    font-size: 0.9rem;
    margin-bottom: 1rem;
    font-family: var(--font-body);
  }
  
  .post-meta time {
    font-weight: 500;
    color: var(--color-text-light);
  }
  
  .author {
    margin-left: 1rem;
    color: var(--color-text-light);
    font-weight: 500;
  }
  
  .updated {
    margin-left: 1rem;
    font-style: italic;
    color: var(--color-text-light);
  }
  
  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }
  
  .tag {
    background: rgba(10, 35, 66, 0.05);
    color: var(--deep-navy);
    padding: 0.4rem 0.8rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    border: 1px solid var(--color-border);
    font-family: var(--font-body);
    text-decoration: none;
    display: inline-block;
  }
  
  .tag:hover {
    background: rgba(10, 35, 66, 0.1);
    color: var(--gold-accent);
  }
  
  .post-content {
    padding: 2.5rem;
    margin: 2rem 0;
  }

  :global(.mermaid-wrapper) {
    overflow-x: auto;
    margin: 2rem 0;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: #fff;
    padding: 1.5rem;
    text-align: center;
  }

  :global(.mermaid svg) {
    max-width: 100%;
    height: auto;
  }

  @media (max-width: 768px) {
    .blog-post {
      padding: 0.5rem 0.5rem;
      margin-top: -0.5rem;
    }

    .post-header {
      padding: 1rem;
      margin: 0.5rem 0;
    }

    .post-content {
      padding: 1rem;
      margin: 0.5rem 0;
      font-size: 1rem;
      line-height: 1.7;
    }

    .post-header h1 {
      font-size: 2rem;
    }

    .blog-footer {
      padding: 1rem 0;
      margin-top: 0.5rem;
      margin-bottom: -0.5rem;
    }

    .content-with-sidebar {
      gap: 1.5rem;
    }
  }
</style>
 