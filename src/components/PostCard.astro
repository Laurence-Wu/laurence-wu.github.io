---
import { formatDate } from '../utils/date';
import { getUrl } from '../utils/url';
import TagBadge from './TagBadge.astro';

export interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
  slug: string;
  thumbnail?: string;
  type?: 'blog' | 'project';
  author?: string;
}

const {
  title,
  description,
  pubDate,
  tags = [],
  slug,
  thumbnail,
  type = 'blog',
  author,
} = Astro.props;

const href = getUrl(type === 'blog' ? `/blog/${slug}/` : `/projects/${slug}/`);
const tagBaseHref = type === 'blog' ? '/blog/tag/' : '/blog/tag/';
---

<article class="post-card card hover-lift">
  {thumbnail && (
    <a href={href} class="thumbnail-link">
      <img src={thumbnail} alt={title} class="thumbnail" loading="lazy" />
    </a>
  )}
  <div class="card-body">
    <header>
      <h2><a href={href}>{title}</a></h2>
      <div class="meta">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {author && <span class="author">by {author}</span>}
      </div>
    </header>

    {description && <p class="description">{description}</p>}

    {tags.length > 0 && (
      <div class="tags">
        {tags.map(tag => (
          <TagBadge label={tag} href={getUrl(`${tagBaseHref}${tag}/`)} />
        ))}
      </div>
    )}

    <a href={href} class="read-more">Read more →</a>
  </div>
</article>

<style>
  .post-card {
    overflow: hidden;
  }

  .thumbnail-link {
    display: block;
    overflow: hidden;
  }

  .thumbnail {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .thumbnail-link:hover .thumbnail {
    transform: scale(1.03);
  }

  .card-body {
    padding: 1.5rem;
  }

  h2 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    margin-bottom: 0.4rem;
  }

  h2 a {
    color: var(--deep-navy);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  h2 a:hover {
    color: var(--gold-accent);
  }

  .meta {
    display: flex;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--color-text-light);
    font-family: var(--font-body);
    margin-bottom: 0.75rem;
  }

  time {
    font-weight: 500;
    color: #8A9A7E;
  }

  .author {
    color: #39647c;
    font-weight: 500;
  }

  .description {
    color: #555;
    line-height: 1.65;
    font-family: var(--font-accent);
    font-size: 1rem;
    margin-bottom: 1rem;
  }

  .tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .read-more {
    color: var(--gold-accent);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    font-family: var(--font-body);
    transition: color 0.2s ease;
  }

  .read-more:hover {
    color: var(--color-gold-light);
  }
</style>
