---
import { formatDate } from '../utils/date';
import TagBadge from './TagBadge.astro';
import { getUrl } from '../utils/url';

export interface Props {
  pubDate: Date;
  author?: string;
  tags?: string[];
  tagBaseHref?: string; // e.g. '/blog/tag/' or '/projects/tag/'
}

const { pubDate, author, tags = [], tagBaseHref = '/blog/tag/' } = Astro.props;
---

<div class="post-meta-block">
  <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
  {author && <span class="author">by {author}</span>}
  {tags.length > 0 && (
    <div class="post-meta-tags">
      {tags.map(tag => (
        <TagBadge label={tag} href={getUrl(`${tagBaseHref}${tag}/`)} />
      ))}
    </div>
  )}
</div>

<style>
  .post-meta-block {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    color: var(--color-text-light);
    font-size: 0.9rem;
    font-family: var(--font-body);
    margin-bottom: 1rem;
  }

  time {
    font-weight: 500;
    color: var(--color-text-light);
  }

  .author {
    color: var(--color-text-light);
    font-weight: 500;
  }

  .post-meta-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
</style>
