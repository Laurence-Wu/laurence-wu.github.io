---
interface Props {
  allBlogPosts: any[];
  allProjects: any[];
}

import { getUrl } from '../utils/url';

const { allBlogPosts, allProjects } = Astro.props;
---

<div class="search-container">
  <div class="search-input-wrapper">
    <div class="search-icon-wrapper">
      <svg viewBox="0 0 24 24" fill="none" class="search-icon-svg" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.35-4.35"></path>
      </svg>
    </div>
    <input 
      type="text" 
      id="search-input" 
      placeholder="Search blogs & projects..." 
      autocomplete="off"
      aria-label="Search blogs and projects"
      aria-haspopup="listbox"
      aria-expanded="false"
    />
    <kbd class="search-shortcut" title="Press / to focus search">/</kbd>
    <button id="clear-search" class="clear-btn hidden" type="button" aria-label="Clear search">×</button>
  </div>
  
  <div id="search-results" class="search-results hidden" role="listbox">
    <div id="results-count-container" class="results-count-wrapper">
      <span id="results-count">0 results</span>
    </div>
    <div id="results-list" class="results-list"></div>
  </div>
</div>

<style>
  .search-container {
    position: relative;
    margin-bottom: 1.5rem;
    z-index: 100;
  }

  .search-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
  }

  #search-input {
    width: 100%;
    padding: 0.75rem 2.5rem 0.75rem 2.5rem;
    border: 2px solid var(--color-border, #e2e8f0);
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-family: var(--font-body);
    background: white;
    color: var(--deep-navy, #2d3748);
    transition: all 0.3s ease;
    outline: none;
  }

  #search-input:focus {
    border-color: #39647c;
    box-shadow: 0 0 0 3px rgba(57, 100, 124, 0.15);
  }

  #search-input::placeholder {
    color: #94a3b8;
  }
  
  .search-icon-wrapper {
    position: absolute;
    left: 0.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 20;
  }
  
  .search-icon-svg {
    width: 1.1rem;
    height: 1.1rem;
    color: #94a3b8;
    z-index: 20;
  }

  #search-input:focus ~ .search-icon-wrapper .search-icon-svg {
    color: #39647c;
  }

  .search-shortcut {
    position: absolute;
    right: 0.8rem;
    background: #f1f5f9;
    border: 1px solid #e2e8f0;
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
    font-size: 0.7rem;
    color: #94a3b8;
    font-family: var(--font-code, monospace);
    pointer-events: none;
    transition: opacity 0.2s;
  }

  #search-input:focus ~ .search-shortcut {
    display: none;
  }

  .clear-btn {
    position: absolute;
    right: 0.5rem;
    width: 1.5rem;
    height: 1.5rem;
    background: #f1f5f9;
    border: none;
    cursor: pointer;
    color: #64748b;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    line-height: 1;
    transition: all 0.2s ease;
    z-index: 10;
  }

  .clear-btn.hidden {
    display: none;
  }

  .clear-btn:hover {
    background: #e2e8f0;
    color: #334155;
  }

  .search-results {
    position: absolute;
    top: 100%;
    left: 0;
    margin-top: 0.5rem;
    min-width: 400px;
    width: 100%;
    background: white;
    border: 1px solid var(--color-border, #e2e8f0);
    border-radius: 0.75rem;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15), 0 4px 12px rgba(0, 0, 0, 0.08);
    z-index: 1000;
    max-height: 440px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .search-results.hidden {
    display: none;
  }

  .results-count-wrapper {
    padding: 0.6rem 1rem;
    border-bottom: 1px solid #e2e8f0;
    background: #f8fafc;
    font-size: 0.75rem;
    font-weight: 600;
    color: #64748b;
    border-radius: 0.75rem 0.75rem 0 0;
  }

  .results-list {
    max-height: 360px;
    overflow-y: auto;
    overflow-x: hidden;
    scroll-behavior: smooth;
    flex-grow: 1;
  }

  .results-list::-webkit-scrollbar {
    width: 6px;
  }

  .results-list::-webkit-scrollbar-track {
    background: #f1f5f9;
  }

  .results-list::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 3px;
  }

  .results-list::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }

  /* --- Result groups --- */
  .result-group-header {
    padding: 0.5rem 1rem 0.3rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #94a3b8;
    background: #fafbfc;
    border-bottom: 1px solid #f1f5f9;
  }

  /* --- Result items --- */
  .result-item {
    display: block;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #f1f5f9;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease;
    cursor: pointer;
  }

  .result-item:hover,
  .result-item.active {
    background: linear-gradient(135deg, #f8fafc, #edf4f8);
  }

  .result-item.active {
    border-left: 3px solid #39647c;
  }

  .result-item:last-child {
    border-bottom: none;
  }

  .result-item::after {
    display: none;
  }

  .result-title {
    font-weight: 600;
    color: #2d3748;
    margin-bottom: 0.25rem;
    font-size: 0.85rem;
    line-height: 1.3;
    word-break: break-word;
  }

  .result-description {
    color: #64748b;
    font-size: 0.75rem;
    line-height: 1.4;
    margin-bottom: 0.5rem;
    word-break: break-word;
    white-space: normal;
    display: block;
  }

  .read-more {
    font-weight: 600;
    color: #39647c;
    font-size: 0.75rem;
    display: inline-block;
  }

  .result-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    color: #94a3b8;
  }

  .result-type {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: white;
    padding: 0.1rem 0.5rem;
    border-radius: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.65rem;
  }

  .result-type.blog {
    background: linear-gradient(135deg, #39647c, #4a8da8);
  }

  .result-type.project {
    background: linear-gradient(135deg, #8A9A7E, #6b8f5e);
  }

  /* --- Highlight --- */
  mark {
    background: linear-gradient(135deg, rgba(212, 175, 55, 0.3), rgba(138, 154, 126, 0.3));
    padding: 0.05em 0.15em;
    border-radius: 0.2em;
    color: inherit;
    font-weight: 600;
  }

  /* --- No results --- */
  .no-results {
    padding: 2rem 1.5rem;
    text-align: center;
    color: #64748b;
    font-size: 0.9rem;
    background: linear-gradient(135deg, #f8fafc, #f1f5f9);
    border-radius: 0 0 0.75rem 0.75rem;
  }

  .no-results-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    opacity: 0.6;
  }

  .no-results-message {
    font-weight: 500;
    color: #475569;
    line-height: 1.5;
  }

  .no-results-hint {
    font-size: 0.8rem;
    color: #94a3b8;
    margin-top: 0.5rem;
    font-style: italic;
  }

  /* --- Recents label --- */
  .recent-label {
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
    color: #94a3b8;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* --- Mobile --- */
  @media (max-width: 640px) {
    .search-results {
      left: 0 !important;
      right: 0 !important;
      min-width: 100% !important;
      max-height: 60vh;
    }

    .search-shortcut {
      display: none;
    }
  }
</style>

<script type="module" define:vars={{ allBlogPosts, allProjects, getUrl }}>
  async function loadMiniSearch() {
    try {
      const { default: MiniSearch } = await import('minisearch');
      return MiniSearch;
    } catch (error) {
      return null;
    }
  }
  
  class SearchManager {
    constructor() {
      this.miniSearch = null;
      this.documents = [];
      this.activeIndex = -1;
      this.searchInput = document.getElementById('search-input');
      this.searchResults = document.getElementById('search-results');
      this.resultsList = document.getElementById('results-list');
      this.resultsCount = document.getElementById('results-count');
      this.clearBtn = document.getElementById('clear-search');
      this.shortcutHint = document.querySelector('.search-shortcut');
      this.debounceTimer = null;
      
      this.init();
    }
    
    async init() {
      this.documents = this.prepareDocuments();
      
      const MiniSearch = await loadMiniSearch();
      if (MiniSearch) {
        this.miniSearch = new MiniSearch({
          fields: ['title', 'description', 'tags', 'body'],
          storeFields: ['title', 'description', 'pubDate', 'type', 'slug', 'tags'],
          searchOptions: {
            boost: { title: 3, tags: 2, description: 1.5, body: 0.5 },
            fuzzy: (term) => term.length > 3 ? 0.2 : false,
            prefix: true
          }
        });
        this.miniSearch.addAll(this.documents);
      }
      
      this.bindEvents();
    }
    
    prepareDocuments() {
      const documents = [];
      
      allBlogPosts.forEach(post => {
        documents.push({
          id: `blog-${post.slug}`,
          title: post.data.title,
          description: post.data.description || '',
          pubDate: post.data.pubDate,
          type: 'blog',
          slug: post.slug,
          tags: (post.data.tags || []).join(' '),
          body: (post.body || '').slice(0, 2000) // Index first 2000 chars of body
        });
      });
      
      allProjects.forEach(project => {
        documents.push({
          id: `project-${project.slug}`,
          title: project.data.title,
          description: project.data.description || '',
          pubDate: project.data.pubDate,
          type: 'project',
          slug: project.slug,
          tags: (project.data.tags || []).join(' '),
          body: (project.body || '').slice(0, 2000)
        });
      });
      
      return documents;
    }
    
    bindEvents() {
      // Hide/Show clear button based on input
      this.searchInput.addEventListener('input', (e) => {
        if (e.target.value.length > 0) {
          this.clearBtn.classList.remove('hidden');
          if (this.shortcutHint) this.shortcutHint.style.display = 'none';
        } else {
          this.clearBtn.classList.add('hidden');
          if (this.shortcutHint) this.shortcutHint.style.display = 'block';
        }
        
        clearTimeout(this.debounceTimer);
        this.debounceTimer = setTimeout(() => {
          this.handleRealtimeSearch(e);
        }, 200);
      });
      
      // Keyboard navigation
      this.searchInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          if (this.activeIndex >= 0) {
            this.navigateToActive();
          } else {
            this.performSearch();
          }
        } else if (e.key === 'Escape') {
          this.clearSearch();
        } else if (e.key === 'ArrowDown') {
          e.preventDefault();
          this.moveActive(1);
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          this.moveActive(-1);
        }
      });
      
      // Focus handling
      this.searchInput.addEventListener('focus', () => {
        if (!this.searchInput.value.trim()) {
          this.showRecent();
        }
        if (this.shortcutHint) this.shortcutHint.style.display = 'none';
      });
      
      this.searchInput.addEventListener('blur', () => {
        if (!this.searchInput.value.trim() && this.shortcutHint) {
          this.shortcutHint.style.display = 'block';
        }
      });
      
      // Clear search
      this.clearBtn.addEventListener('click', this.clearSearch.bind(this));
      
      // Close on outside click
      document.addEventListener('click', (e) => {
        if (!e.target.closest('.search-container')) {
          this.hideResults();
        }
      });
      
      // Global "/" shortcut to focus search
      document.addEventListener('keydown', (e) => {
        if (e.key === '/' && !e.ctrlKey && !e.metaKey && document.activeElement !== this.searchInput) {
          const tag = document.activeElement?.tagName?.toLowerCase();
          if (tag !== 'input' && tag !== 'textarea' && !document.activeElement?.isContentEditable) {
            e.preventDefault();
            this.searchInput.focus();
          }
        }
      });
    }
    
    // --- Keyboard navigation ---
    moveActive(direction) {
      const items = this.resultsList.querySelectorAll('.result-item');
      if (items.length === 0) return;
      
      // Remove current active
      if (this.activeIndex >= 0 && this.activeIndex < items.length) {
        items[this.activeIndex].classList.remove('active');
      }
      
      this.activeIndex += direction;
      if (this.activeIndex < 0) this.activeIndex = items.length - 1;
      if (this.activeIndex >= items.length) this.activeIndex = 0;
      
      items[this.activeIndex].classList.add('active');
      items[this.activeIndex].scrollIntoView({ block: 'nearest' });
    }
    
    navigateToActive() {
      const items = this.resultsList.querySelectorAll('.result-item');
      if (this.activeIndex >= 0 && this.activeIndex < items.length) {
        const href = items[this.activeIndex].getAttribute('href');
        if (href) window.location.href = href;
      }
    }
    
    // --- Search logic ---
    handleRealtimeSearch(e) {
      const query = e.target.value.trim();
      this.activeIndex = -1;
      
      if (query.length >= 2) {
        const results = this.search(query, 10);
        this.displayResults(results, query);
      } else if (query.length === 0) {
        this.showRecent();
      } else {
        this.hideResults();
      }
    }
    
    performSearch() {
      const query = this.searchInput.value.trim();
      this.activeIndex = -1;
      
      if (query.length < 2) {
        this.displayNoResults('Please enter at least 2 characters to search');
        return;
      }
      
      const results = this.search(query, 10);
      this.displayResults(results, query);
    }
    
    search(query, limit = 10) {
      if (this.miniSearch) {
        return this.miniSearch.search(query, { limit });
      }
      return this.fallbackSearch(query, limit);
    }
    
    fallbackSearch(query, limit) {
      const queryLower = query.toLowerCase();
      const results = [];
      
      for (const doc of this.documents) {
        let score = 0;
        if (doc.title.toLowerCase().includes(queryLower)) score += 3;
        if (doc.tags.toLowerCase().includes(queryLower)) score += 2;
        if (doc.description.toLowerCase().includes(queryLower)) score += 1.5;
        if (doc.body.toLowerCase().includes(queryLower)) score += 0.5;
        
        if (score > 0) {
          results.push({ ...doc, score });
        }
      }
      
      return results.sort((a, b) => b.score - a.score).slice(0, limit);
    }
    
    // --- Recent posts ---
    showRecent() {
      const recent = [...this.documents]
        .filter(d => d.pubDate)
        .sort((a, b) => new Date(b.pubDate) - new Date(a.pubDate))
        .slice(0, 5);
      
      if (recent.length === 0) return;
      
      this.resultsCount.textContent = 'Recent';
      this.resultsList.innerHTML = `
        <div class="recent-label">📌 Recent Posts</div>
        ${recent.map(r => this.renderItem(r, '')).join('')}
      `;
      this.showResults();
    }
    
    // --- Display ---
    displayResults(results, query) {
      this.resultsCount.textContent = `${results.length} result${results.length !== 1 ? 's' : ''}`;
      
      if (results.length === 0) {
        this.displayNoResults(`No results found for "${query}"`);
        return;
      }
      
      // Group by type
      const blogs = results.filter(r => r.type === 'blog');
      const projects = results.filter(r => r.type === 'project');
      
      let html = '';
      if (blogs.length > 0) {
        html += `<div class="result-group-header">📝 Blog Posts (${blogs.length})</div>`;
        html += blogs.map(r => this.renderItem(r, query)).join('');
      }
      if (projects.length > 0) {
        html += `<div class="result-group-header">🚀 Projects (${projects.length})</div>`;
        html += projects.map(r => this.renderItem(r, query)).join('');
      }
      
      this.resultsList.innerHTML = html;
      this.showResults();
    }
    
    renderItem(result, query) {
      const date = result.pubDate
        ? new Date(result.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })
        : '';
      
      const url = result.type === 'blog' 
        ? `/blog/${result.slug}/`
        : `/projects/${result.slug}/`;
      
      const title = query ? this.highlightText(result.title, query) : result.title;
      
      let descText = result.description || '';
      // Truncate descriptions and add 'Read more' link
      if (descText.length > 100) {
        descText = descText.substring(0, 97) + '...';
      }
      const highlightedDesc = query ? this.highlightText(descText, query) : descText;
      const descHtml = descText ? `<div class="result-description">${highlightedDesc} <span class="read-more">Read more →</span></div>` : '';
      
      return `
        <a href="${url}" class="result-item" role="option">
          <div class="result-title">${title}</div>
          ${descHtml}
          <div class="result-meta">
            <span class="result-type ${result.type}">${result.type}</span>
            ${date ? `<span class="result-date">📅 ${date}</span>` : ''}
          </div>
        </a>
      `;
    }
    
    displayNoResults(message) {
      this.resultsCount.textContent = '0 results';
      this.resultsList.innerHTML = `
        <div class="no-results">
          <div class="no-results-icon">🔍</div>
          <div class="no-results-message">${message}</div>
          <div class="no-results-hint">Try using different keywords or check your spelling</div>
        </div>
      `;
      this.showResults();
    }
    
    highlightText(text, query) {
      if (!query || !text) return text || '';
      const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
      return text.replace(regex, '<mark>$1</mark>');
    }
    
    // --- Display Control ---
    showResults() {
      this.searchResults.classList.remove('hidden');
      this.searchInput.setAttribute('aria-expanded', 'true');
    }
    
    hideResults() {
      this.searchResults.classList.add('hidden');
      this.searchInput.setAttribute('aria-expanded', 'false');
      this.activeIndex = -1;
    }
    
    clearSearch() {
      this.searchInput.value = '';
      this.clearBtn.classList.add('hidden');
      if (this.shortcutHint) this.shortcutHint.style.display = 'block';
      this.hideResults();
      this.searchInput.focus();
    }
  }
  
  document.addEventListener('DOMContentLoaded', () => {
    new SearchManager();
  });
</script>